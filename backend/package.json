{
  "name": "backend",
  "version": "1.0.0",
  "description": "Health Metrics Tracker backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test npm run build && NODE_ENV=test node --test dist/src/tests/*.test.ts",
    "prisma:generate": "npm run prisma:cli -- generate",
    "prisma:migrate": "npm run prisma:cli -- migrate dev --name init",
    "prisma:cli": "node ./node_modules/prisma/build/index.js"
  },
  "dependencies": {
    "@prisma/client": "^7.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "prisma": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
