generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int           @id @default(autoincrement())
  name     String
  email    String        @unique
  password String
  metrics  HealthMetric[]
}

model HealthMetric {
  id               Int      @id @default(autoincrement())
  userId           Int
  date             DateTime
  heartRate        Int?
  steps            Int?
  sleepHours       Float?
  calories         Int?
  weight           Float?
  bloodPressureSys Int?
  bloodPressureDia Int?
  glucose          Int?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}
